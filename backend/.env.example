# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/deskie_lie

# ── Google Places API ─────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── NVIDIA NIM (free tier) ─────────────────────────────────────────────
# Get from: https://build.nvidia.com → Sign in → Get API Key (top right)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ── SerpAPI (optional — for hiring/social signals) ───────────────────
SERPAPI_KEY=

# ── Adzuna (free official jobs API — hiring-first discovery) ─────────
# Register free at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Jooble (free jobs API — merged with Adzuna in hiring-first) ───────
# Request a free key at https://jooble.org/api/about
JOOBLE_API_KEYS=

# ── Apollo.io (verified decision-maker contacts; optional) ───────────
# Comma-separated keys are pooled — rotates to the next on quota errors.
# NOTE: requires a PAID Apollo plan — free-plan keys are rejected with
# API_INACCESSIBLE and the SerpAPI fallback takes over.
APOLLO_API_KEYS=

# Classic-mode per-lead hiring/ads verification via SerpAPI costs
# 2 searches per lead — the #1 free-quota drain. Off by default.
ENABLE_SERPAPI_ENRICHER=false

# ── App Settings ──────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# -- Outreach sending (optional, resend.com) ------------------------------
RESEND_API_KEY=
OUTREACH_FROM_EMAIL=
OUTREACH_REPLY_TO=
